# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to git — it's in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ───────────────────────────────────────────────────────────────────
MAIN_URL=https://www.sololaveritestudio.com
SHOP_URL=https://shop.sololaveritestudio.com

# ── YouTube API ───────────────────────────────────────────────────────────────
# Get your key at: https://console.cloud.google.com/apis/credentials
#YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx

# ── Vite (exposed to browser — public vars only) ──────────────────────────────
VITE_MAIN_URL=https://www.sololaveritestudio.com
VITE_SHOP_URL=https://shop.sololaveritestudio.com

# ── GitHub Deploy ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
